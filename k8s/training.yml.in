apiVersion: batch/v1
kind: Job
metadata:
  name: ${JOB_NAME}
  namespace: training
  labels:
    app.kubernetes.io/name: churn-model
    app.kubernetes.io/component: training
spec:
  backoffLimit: 1

  template:
    metadata:
      labels:
        app.kubernetes.io/name: churn-model
        app.kubernetes.io/component: training

      annotations:
        gke-gcsfuse/volumes: "true"

    spec:
      serviceAccountName: model-workload
      restartPolicy: Never

      containers:
        - name: training
          image: ${GKE_REGION}-docker.pkg.dev/${GKE_PROJECT}/ml-training-images/trainandscore:latest
          imagePullPolicy: Always

          command:
            - python
            - /train_and_score.py

          args:
            - train
            - churn-prediction
            - /data

          env:
            - name: MLFLOW_TRACKING_URI
              value: http://mlflow.mlflow.svc.cluster.local:5000

          resources:
            requests:
              cpu: "1"
              memory: 2Gi
            limits:
              cpu: "2"
              memory: 4Gi

          volumeMounts:
            - name: data
              mountPath: /data

      volumes:
        - name: data
          csi:
            driver: gcsfuse.csi.storage.gke.io
            readOnly: false

            volumeAttributes:
              bucketName: ${DATA_BUCKET_NAME}
